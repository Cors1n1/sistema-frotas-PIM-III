# ═══════════════════════════════════════════════════
# .gitignore — Sistema de Gestão de Frotas (PIM III)
# ═══════════════════════════════════════════════════

# ── Variáveis de Ambiente (CRÍTICO: contém senhas) ──
.env
*.env
.env.*

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ── Ambientes Virtuais ──
venv/
env/
ENV/
.venv/

# ── IDE / Editores ──
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Sistema Operacional ──
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Logs e temporários ──
*.log
*.tmp
*.bak
*.cache

# ── Banco de Dados local ──
*.sqlite3
*.db

# ── Node (caso use futuramente) ──
node_modules/
package-lock.json

# ── Documentos binários do professor (opcional) ──
Manual_PIM_III*.docx
Manual_PIM_III - ADS.docx